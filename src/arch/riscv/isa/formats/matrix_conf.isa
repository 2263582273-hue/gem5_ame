def template MSetTileniBranchTarget {{
    std::unique_ptr<PCStateBase>
    %(class_name)s::branchTarget(const PCStateBase &branch_pc) const
    {
        auto &rpc = branch_pc.as<RiscvISA::PCState>();

        uint64_t rd_bits = machInst.rd;
        uint64_t rs1_bits = -1;
        uint64_t requested_mtilen = imm10;

        MTYPE current_mtype = rpc.mtype();
        uint32_t melen = getMelen(current_mtype.msew, current_mtype.msew);
        uint32_t mtilenmax =  getMtilenMax(mrlen, melen);
        uint32_t new_mtilen = getNewMtilen(
           rpc.mtilen(), requested_mtilen, mtilenmax, rd_bits, rs1_bits);

        std::unique_ptr<PCState> npc(dynamic_cast<PCState*>(rpc.clone()));
        npc->set(rvSext(npc->pc() + 4));
        npc->new_mconf(true);
        npc->mtilen(new_mtilen);
        return npc;
    }
}};
