    )
    declareTemplate = eval(declare_class)

    header_output = declareTemplate.subst(iop)
    decoder_output = MSetTilemConstructor.subst(iop)
    decode_block = MSetTilemDecodeBlock.subst(iop)
    exec_output = MSetTilemExecute.subst(iop)
}};

def template MSetTilemDeclare {{
    class %(class_name)s : public %(base_class)s
    {
      private:
        %(reg_idx_arr_decl)s;
        uint32_t getNewMtilem(
            uint32_t, uint32_t, uint32_t, uint64_t, uint64_t) const;

      public:
        %(class_name)s(ExtMachInst machInst, uint32_t mlen, uint32_t mrlen);
        Fault execute(ExecContext *, trace::InstRecord *) const override;

        using %(base_class)s::generateDisassembly;
    };
}};

def template MSetTilemConstructor {{
%(class_name)s::%(class_name)s(ExtMachInst _machInst, uint32_t _mlen, uint32_t _mrlen)
    : %(base_class)s("%(mnemonic)s", _machInst, _mlen, _mrlen, %(op_class)s)
    {
        %(set_reg_idx_arr)s;
        %(constructor)s;
    }
}};

def template MSetTilemDecodeBlock {{
    return new %(class_name)s(machInst, mlen, mrlen);
}};

def template MSetTilemExecute {{
    uint32_t
    %(class_name)s::getNewMtilem(
        uint32_t currentMtilem, uint32_t reqMtilem,
        uint32_t mtilemmax, uint64_t rdBits, uint64_t rs1Bits) const
    {
        uint32_t newMtilem = 0;
        if (mtilemmax == 0) {
            newMtilem = 0;
        } else if (rdBits == 0 && rs1Bits == 0) {
            newMtilem = (currentMtilem > mtilemmax) ? mtilemmax : currentMtilem;
        } else if (rdBits != 0 && rs1Bits == 0) {
            newMtilem = mtilemmax;
        } else if (rs1Bits != 0) {
            newMtilem = (reqMtilem > mtilemmax) ? mtilemmax : reqMtilem;
        }
        return newMtilem;
    }

    Fault
    %(class_name)s::execute(ExecContext *xc,
        trace::InstRecord *traceData) const
    {

        %(op_decl)s;
        %(op_rd)s;
        %(code)s;

        mtilemmax =  getMtilemMax(mlen, mrlen);
        uint32_t new_mtilem = getNewMtilem(
            current_mtilem, requested_mtilem, mtilemmax, rd_bits, rs1_bits);

        %(write_code)s;

        %(op_wb)s;
        return NoFault;
    }
}};

