def template MSetTilemiBranchTarget {{
    std::unique_ptr<PCStateBase>
    %(class_name)s::branchTarget(const PCStateBase &branch_pc) const
    {
        auto &rpc = branch_pc.as<RiscvISA::PCState>();

        uint64_t rd_bits = machInst.rd;
        uint64_t rs1_bits = -1;
        uint64_t requested_mtilem = imm10;


        uint32_t mtilemmax =  getMtilemMax(mlen, mrlen);
        uint32_t new_mtilem = getNewMtilem(
           rpc.mtilem(), requested_mtilem, mtilemmax, rd_bits, rs1_bits);

        std::unique_ptr<PCState> npc(dynamic_cast<PCState*>(rpc.clone()));
        npc->set(rvSext(npc->pc() + 4));
        npc->new_mconf(true);
        npc->mtilem(new_mtilem);
        return npc;
    }
}};

