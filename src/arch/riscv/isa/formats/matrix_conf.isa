// Matrix Extension
def format MConfOp(code, write_code, declare_class, branch_class, *flags) {{
    iop = InstObjParams(
        name,
        Name,
        'MConfOp',
        {
            'code': code,
            'write_code': write_code,
        },
        flags
    )
    declareTemplate = eval(declare_class)

    header_output = declareTemplate.subst(iop)
    decoder_output = MConfConstructor.subst(iop)
    decode_block = MConfDecodeBlock.subst(iop)
    exec_output = MConfExecute.subst(iop)
    if name != 'msettype':
        branchTargetTemplate = eval(branch_class)
        exec_output += branchTargetTemplate.subst(iop)
}};

def template MConfConstructor {{
    %(class_name)s::%(class_name)s(ExtMachInst _machInst)
        : %(base_class)s("%(mnemonic)s", _machInst,%(op_class)s)
        {
            %(set_reg_idx_arr)s;
            %(constructor)s;
        }
}};

def template MConfDecodeBlock {{
    return new %(class_name)s(machInst);
}};

def template MConfExecute {{
    MTYPE
    %(class_name)s::getNewMtype(
        MTYPE oldMtype, MTYPE reqMtype)  const
        {
               MTYPE newMtype = oldMtype;
        if (oldMtype != reqMtype) {
            newMtype = reqMtype;
        }
        // TODO: For each type field,
        // a value 0 means the corresponding type is disabled.
        // Write non-zero value to enable
        // matrix multiplication operation of the specified type.
        // 0 will be returned and
        //  mill will be set if the type is not supported.
        newMtype.mill=0;
        return newMtype;
    }

    Fault
    %(class_name)s::execute(ExecContext *xc,
        trace::InstRecord *traceData) const
    {
        MISA misa = xc->readMiscReg(MISCREG_ISA);
        STATUS status = xc->readMiscReg(MISCREG_STATUS);
        if (!misa.rvmatrix || status.ms == MPUStatus::OFF) {
            return std::make_shared<IllegalInstFault>(
                "RVMatrix disabled or MPU is off", machInst);
        }

        %(op_decl)s;
        %(op_rd)s;
        %(code)s;

        new_mtype = getNewMtype(Mtype, new_mtype);

        %(write_code)s;

        %(op_wb)s;
        return NoFault;
    }
 }};

 def template MSetTypeDeclare {{
    //
    // Static instruction class for "%(mnemonic)s".
    //
    class %(class_name)s : public %(base_class)s
    {
      private:
        %(reg_idx_arr_decl)s;
        MTYPE getNewMtype(MTYPE, MTYPE) const;

      public:
        /// Constructor.
        %(class_name)s(ExtMachInst machInst);
        Fault execute(ExecContext *, trace::InstRecord *) const override;

        using %(base_class)s::generateDisassembly;

    };
}};

def template MSetTypeImmDeclare {{
    //
    // Static instruction class for "%(mnemonic)s".
    //
    class %(class_name)s : public %(base_class)s
    {
      private:
        %(reg_idx_arr_decl)s;
        MTYPE getNewMtype(MTYPE, MTYPE) const;

      public:
        /// Constructor.
        %(class_name)s(ExtMachInst machInst);
        Fault execute(ExecContext *, trace::InstRecord *) const override;
        std::unique_ptr<PCStateBase> branchTarget(
            const PCStateBase &branch_pc) const override;

        using StaticInst::branchTarget;
        using %(base_class)s::generateDisassembly;

    };
}};

def template MSetTypeImmBranchTarget {{
    std::unique_ptr<PCStateBase>
    %(class_name)s::branchTarget(const PCStateBase &branch_pc) const
    {
        auto &rpc = branch_pc.as<RiscvISA::PCState>();
        uint64_t Mtype = rpc.mtype();
        %(code)s;
        new_mtype = getNewMtype(Mtype, new_mtype);

        std::unique_ptr<PCState> npc(dynamic_cast<PCState*>(rpc.clone()));
        npc->set(rvSext(npc->pc() + 4));
        npc->new_mconf(true);
        npc->mtype(new_mtype);
        return npc;
    }
}};

def format MSetTilemOp(code, write_code, declare_class, branch_class, *flags) {{
    iop = InstObjParams(
