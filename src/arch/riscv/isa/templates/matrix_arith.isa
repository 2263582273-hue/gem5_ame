        _numDestRegs = 0;
        %(set_dest_reg_idx)s;
        %(set_src_reg_idx)s;
    }

    %(declare_marith_template)s;
}};

def template MatrixFloatCvtMacroConstructor {{
    template<typename ElemType>
    %(class_name)s<ElemType>::%(class_name)s(ExtMachInst _machInst,
                                            uint64_t _mlen, uint64_t _mrlen,
                                            uint64_t _mtilem, uint64_t _mtilek,
                                            uint64_t _mtilen, MTYPE _mtype)
        : %(base_class)s("%(mnemonic)s", _machInst, %(op_class)s,
                        _mlen, _mrlen, _mtilem, _mtilek, _mtilen, _mtype)
    {
        %(set_reg_idx_arr)s;
        _numSrcRegs = 0;
        _numDestRegs = 0;
        %(set_dest_reg_idx)s;
        %(set_src_reg_idx)s;

        uint64_t num_microops = mtilem;

        int64_t remaining_microops = mtilem;
        StaticInstPtr microop;

        if (remaining_microops == 0) {
            microop = new MatrixNopMicroInst(_machInst);
            this->microops.push_back(microop);
        }

        for (int i = 0; i < num_microops; ++i) {
            microop = new %(class_name)sMicro<ElemType>(_machInst, i, mlen, mrlen, mtilem, mtilek, mtilen, mtype);
            microop->setDelayedCommit();
            this->microops.push_back(microop);
            remaining_microops -= 1;
        }

        this->microops.front()->setFirstMicroop();
        this->microops.back()->setLastMicroop();
    }

    %(declare_marith_template)s;
}};
def template MatrixFloatCvtMicroExecute {{
    template <typename ElemType>
    Fault
    %(class_name)s<ElemType>::execute(ExecContext* xc,
                                    trace::InstRecord* traceData) const
    {
            using et = ElemType;
            using ewt = typename double_width<et>::type;
            using ent = typename half_width<et>::type;
            using mu [[maybe_unused]] = decltype(et::v);
            using mwu = decltype(ewt::v);
            using mnu = decltype(ent::v);
            using mhf = decltype(float16_t::v);
            using mf = decltype(float32_t::v);
            using bf=decltype(bfloat16_t::v);
        using et [[maybe_unused]] = ElemType;
        using mu [[maybe_unused]] = decltype(et::v);

        using ewt [[maybe_unused]] = typename double_width<et>::type;
        using mwu [[maybe_unused]] = decltype(ewt::v);


        using ent [[maybe_unused]] = typename half_width<et>::type;
        using mnu [[maybe_unused]] = decltype(ent::v);


        using bf [[maybe_unused]] =decltype(bfloat16_t::v);


        MISA misa = xc->readMiscReg(MISCREG_ISA);
        STATUS status = xc->readMiscReg(MISCREG_STATUS);
        if (!misa.rvmatrix || status.ms == MPUStatus::OFF) {
            return std::make_shared<IllegalInstFault>(
                "RVM is disabled or MPU is off", machInst);
        }

        %(op_decl)s;
        %(op_rd)s;
        %(set_mlenb)s;
        %(set_mrlenb)s;
        %(copy_old_md)s;

        //if (!hasFloatEEW(machInst.eew, mtype.eew) || !hasFloatEEW(machInst.f3, mtype.eew)) {
        //  return std::make_shared<IllegalInstFault>(
        //    "Matrix FP convert: element width not enabled", mtype);
        // }

        uint32_t elem = mtilen;
        size_t i = 0;

        for(; i < elem; i++)
        {
            %(code)s;
        }


        %(op_wb)s;

        return NoFault;
    }

    %(declare_marith_template)s;
}};
def template MatrixFloatWideningAndNarrowingCvtDecodeBlock {{
    switch(mtype.msew) {
        case 0b000: return new %(class_name)s<float8_t>(machInst, mlen, mrlen,
                                         mtilem, mtilek, mtilen, mtype);
        case 0b001: return new %(class_name)s<float16_t>(machInst, mlen, mrlen,
                                         mtilem, mtilek, mtilen, mtype);
        case 0b010: return new %(class_name)s<float32_t>(machInst, mlen, mrlen,
                                         mtilem, mtilek, mtilen, mtype);
        case 0b011: return new %(class_name)s<float64_t>(machInst, mlen, mrlen,
                                         mtilem, mtilek, mtilen, mtype);
        default: GEM5_UNREACHABLE;}
}};
